<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" version="3.1">

    <servlet>
        <servlet-name>HelloWorld</servlet-name>
        <servlet-class>com.exemplo.HelloWorld</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>HelloWorld</servlet-name>
        <url-pattern>/hello</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HelloYou</servlet-name>
        <servlet-class>com.exemplo.HelloYou</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>HelloYou</servlet-name>
        <url-pattern>/you</url-pattern>
    </servlet-mapping>

</web-app>
